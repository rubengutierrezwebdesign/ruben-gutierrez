---
title: Blog
layout: 'default.njk'
permalink: /blog/
---

<div class="cont pd-100 dt-flex">
    {% for post in collections.current_post | reverse %}
        {% if loop.index0 < 1 %}
            <div>   
                <a href="{{post.url}}" style="text-decoration:none!important;"><h1>{{post.data.title}}</h1></a>
                <p class="large-copy">{{post.data.description}}</p>   
            </div>

            <div>

            </div>
        {% endif %}
    {% endfor %}
</div>

<div class="cont flex flex-wrap">
    {% for post in collections.posts | reverse %}
        {% if loop.index0 < 8 %}
            <li class="mw-50 mb-50 pr-5">
                <article class="">
                    <a href="{{post.url}}"><h3 class="">{{post.data.title}}</h3></a>
                    <p>{{post.data.description}}</p>   
                </article>
            </li>
        {% endif %}
    {% endfor %}
</div>

