---
layout: 'default.njk'
title:  "Local"
permalink: /local/
---
<div class="cont mb-100">

    <div>
                <h1>Local SEO Directory</h1>

    </div>

    <div class="flex">
        {% for post in collections.local | reverse %}
            {% if loop.index0 < 10 %}
                <div class="local-directory">
                    <a href="{{post.url}}" style="text-decoration:none"><h3>{{post.data.title}}</h3></a>
                </div>
            {% endif %}
        {% endfor %}
    </div>
</div>