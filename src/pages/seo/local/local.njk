    <div class="cont mb-100">
        {% for post in collections.local | reverse %}
            {% if loop.index0 < 10 %}
                <div>
                    <a href="{{post.url}}"><h1>{{post.data.title}}</h1></a>
                </div>
            {% endif %}
        {% endfor %}
    </div>