---
title: Blog
layout: 'default.njk'
permalink: /blog/
---
<div class="paa-20">

    <div class="cont mb-100">
        {% for post in collections.current_post | reverse %}
            {% if loop.index0 < 1 %}
                <div>
                    <a href="{{post.url}}"><h1>{{post.data.title}}</h1></a>
                    <p>{{post.data.description}}</p>   
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <div class="cont flex flex-wrap">
        {% for post in collections.posts | reverse %}
            {% if loop.index0 < 8 %}
                <li class="mw-50 mb-50">
                    <article class="">
                        <a href="{{post.url}}"><h2 class="">{{post.data.title}}</h2></a>
                        <p>{{post.data.description}}</p>   
                    </article>
                </li>
            {% endif %}
        {% endfor %}
    </div>

