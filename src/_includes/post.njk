<!DOCTYPE html>
<html lang="en">
{%- include 'head.njk' -%}
<body>
{%- include 'nav.njk' -%}

<div class="main" style="padding-top:85px!important;;">

    <div class="post pd-20">
        <h1>{{title}}<h1>
    </div>

    {{ content  | safe}}

   	<div class="post prev-next paa-20 flex">
        {% if nextPost.url %}
                <p class="ctr mw-50 _14">
                    <strong>Next</strong>: <br>
                    <a class="next" href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
                </p>
            {% endif %}
            {% if prevPost.url %}
                <p class="ctr mw-50 _14">
                    <strong>Previous</strong>:
                    <a class="previous" href="{{ prevPost.url }}">{{ prevPost.data.title }}</a>
                </p>
        {% endif %}
    </div>

    {%- include 'footer.njk' -%}

</div>

</body>
</html>